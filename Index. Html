<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Alyan - Pro Developer</title>

<style>
body{
  margin:0;
  font-family:Arial;
  background:#0b1220;
  color:white;
}

/* HEADER */
header{
  text-align:center;
  padding:60px 20px;
  background:linear-gradient(135deg,#1e3a8a,#0f172a);
}

img{
  width:130px;
  height:130px;
  border-radius:50%;
  border:4px solid white;
}

h1{margin:15px 0 5px;}
.typing{color:#38bdf8;height:25px;}

/* CARDS */
section{padding:20px;}
.card{
  background:#111827;
  margin:15px auto;
  padding:20px;
  border-radius:12px;
  max-width:500px;
  transition:0.3s;
}
.card:hover{transform:scale(1.03);}

/* FORM */
input,textarea{
  width:100%;
  padding:10px;
  margin:8px 0;
  border:none;
  border-radius:8px;
}

button{
  background:#22c55e;
  color:white;
  padding:10px;
  border:none;
  width:100%;
  border-radius:8px;
  cursor:pointer;
}

/* FOOTER */
footer{
  text-align:center;
  padding:20px;
  background:#0f172a;
  margin-top:20px;
}
</style>
</head>

<body>

<header>
  <img src="https://via.placeholder.com/130">
  <h1>Alyan Maher</h1>
  <div class="typing" id="typing"></div>
</header>

<section>

<div class="card">
<h2>About Me</h2>
<p>I am a professional web developer building modern websites.</p>
</div>

<div class="card">
<h2>Skills</h2>
<p>HTML • CSS • JavaScript • WordPress</p>
<p>I know 4+ programming languages</p>
</div>

<div class="card">
<h2>Projects</h2>
<p>✔ Portfolio Website</p>
<p>✔ Business Website</p>
<p>✔ Landing Pages</p>
</div>

<!-- CONTACT FORM -->
<div class="card">
<h2>Contact Me</h2>

<form id="contactForm">
<input type="text" id="name" placeholder="Your Name" required>
<input type="email" id="email" placeholder="Your Email" required>
<textarea id="message" placeholder="Your Message" required></textarea>
<button type="submit">Send Message</button>
</form>

<p id="status"></p>
</div>

</section>

<footer>
© 2026 Alyan | All Rights Reserved
</footer>

<script>

/* typing effect */
const text=["Web Developer","Freelancer","Designer"];
let i=0,j=0,isDeleting=false;

function type(){
let current=text[i];

document.getElementById("typing").textContent=current.substring(0,j);

if(!isDeleting){j++;}else{j--;}

if(j===current.length){
isDeleting=true;
setTimeout(type,1000);return;
}
if(j===0){
isDeleting=false;
i=(i+1)%text.length;
}

setTimeout(type,isDeleting?80:120);
}
type();

/* CONTACT FORM (Google Sheets API optional demo) */
document.getElementById("contactForm").addEventListener("submit",function(e){
e.preventDefault();

let name=document.getElementById("name").value;
let email=document.getElementById("email").value;
let message=document.getElementById("message").value;

document.getElementById("status").innerText="Message Sent Successfully ✅";

// simple demo (real backend ke liye Google Sheets connect hota hai)
console.log({name,email,message});

this.reset();
});
</script>

</body>
</html>
